{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexora POS",
  "version": "1.0.0",
  "identifier": "com.nexora.pos",
  "build": {
    "beforeDevCommand": "npm --prefix ../.. run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix ../.. run build",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexora POS",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.nexora.example http://127.0.0.1:8787; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://updates.nexora.example/{{target}}/{{arch}}/{{current_version}}"],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
